# Copy this to .env and fill in values

# API key for development — prefix must be dk_live_ or dk_test_
DOKR_API_KEY=dk_live_changeme_replace_this

# SQLite path (relative to project root)
DATABASE_URL=sqlite:///./dokr.db

# Max PDF upload size in MB
MAX_FILE_SIZE_MB=50

# Set to "development" or "production"
ENVIRONMENT=development
