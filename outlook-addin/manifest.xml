<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xsi:type="MailApp">

  <Id>d6156df2-03bb-4e1c-8409-a61576c33a57</Id>
  <Version>1.1.0.0</Version>
  <ProviderName>Dokr</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Dokr"/>
  <Description DefaultValue="Send email attachments to Dokr for automatic processing"/>

  <IconUrl DefaultValue="https://djdrewek.github.io/dokr/icon32.png"/>
  <HighResolutionIconUrl DefaultValue="https://djdrewek.github.io/dokr/icon80.png"/>
  <SupportUrl DefaultValue="https://github.com/djdrewek/dokr"/>

  <AppDomains>
    <AppDomain>https://djdrewek.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://djdrewek.github.io/dokr/addin.html"/>
        <RequestedHeight>150</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides
    xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
    xsi:type="VersionOverridesV1_0">

    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <FunctionFile resid="FunctionFile.Url"/>

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="dokr.Group1">
                <Label resid="GroupLabel"/>
                <!-- Button 1: one-click send attachments to Dokr -->
                <Control xsi:type="Button" id="dokr.Button1">
                  <Label resid="ButtonLabel"/>
                  <Supertip>
                    <Title resid="ButtonLabel"/>
                    <Description resid="ButtonTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>sendToDokr</FunctionName>
                  </Action>
                </Control>

                <!-- Button 2: save attachments directly to SharePoint -->
                <Control xsi:type="Button" id="dokr.SharePointButton">
                  <Label resid="SharePointButtonLabel"/>
                  <Supertip>
                    <Title resid="SharePointButtonLabel"/>
                    <Description resid="SharePointButtonTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>saveToSharePoint</FunctionName>
                  </Action>
                </Control>

                <!-- Button 3: open the Dokr task pane (history + settings) -->
                <Control xsi:type="Button" id="dokr.PanelButton">
                  <Label resid="PanelButtonLabel"/>
                  <Supertip>
                    <Title resid="PanelButtonLabel"/>
                    <Description resid="PanelButtonTip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>DokrPanel</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="https://djdrewek.github.io/dokr/icon16.png"/>
        <bt:Image id="Icon32" DefaultValue="https://djdrewek.github.io/dokr/icon32.png"/>
        <bt:Image id="Icon80" DefaultValue="https://djdrewek.github.io/dokr/icon80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="FunctionFile.Url" DefaultValue="https://djdrewek.github.io/dokr/addin.html"/>
        <bt:Url id="Taskpane.Url"     DefaultValue="https://djdrewek.github.io/dokr/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"             DefaultValue="Dokr"/>
        <bt:String id="ButtonLabel"            DefaultValue="Send to Dokr"/>
        <bt:String id="SharePointButtonLabel"  DefaultValue="Save to SharePoint"/>
        <bt:String id="PanelButtonLabel"       DefaultValue="Dokr Panel"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="ButtonTip"         DefaultValue="Upload all attachments in this email to Dokr for automatic processing"/>
        <bt:String id="SharePointButtonTip" DefaultValue="Save all attachments in this email directly to the SharePoint document library"/>
        <bt:String id="PanelButtonTip"    DefaultValue="Open the Dokr submission history and settings panel"/>
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>
</OfficeApp>
